# Database (PostgreSQL — used via Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/codebox"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_COOKIE_EXPIRES_IN=7

# Groq (AI — powers chat, code analysis, and project analysis)
GROQ_API_KEY="your-groq-api-key-from-console.groq.com"

# Resend (transactional email — used for password reset OTP codes)
RESEND_API_KEY="your-resend-api-key-from-resend.com"

# Server
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
